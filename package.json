{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "bun run positions:gen",
    "dev": "next dev --turbopack",
    "prebuild": "bun run positions:gen",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "positions:gen": "bun run scripts/build-positions.ts",
